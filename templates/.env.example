# Environment Variables Template
# Hướng dẫn:
#   1. Copy file này sang .env.local (hoặc .env)
#   2. Điền giá trị thật vào .env.local
#   3. KHÔNG commit .env.local — chỉ commit file này (.env.example)
#   4. Thêm variable mới vào đây trước khi dùng trong code

# ── App ──────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ── Database (nếu dùng) ──────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379

# ── Auth (nếu dùng) ──────────────────────────────
# JWT_SECRET=change-me-to-random-32-chars
# NEXTAUTH_SECRET=change-me-to-random-32-chars
# NEXTAUTH_URL=http://localhost:3000

# ── External APIs ─────────────────────────────────
# Thêm key mới sau khi RAISE trong docs/reports/integration-needs.md
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
